@baseUrl = http://localhost:3000

### ─────────────────────────────────────
### Kiểm tra server
### ─────────────────────────────────────
GET {{baseUrl}}/

### ─────────────────────────────────────
### 1. Tạo user – Nguyen Van A
### ─────────────────────────────────────
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "name": "Nguyen Van A",
  "age": 25,
  "email": "vana@example.com"
}

